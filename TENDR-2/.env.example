# ── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB Atlas ───────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
# The database name "tendr" is injected automatically by db.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>

# ── Redis (Redis Cloud) ─────────────────────────────────
# Get from: https://app.redislabs.com
REDIS_HOST=<your-redis-host>
REDIS_PORT=<your-redis-port>
REDIS_USERNAME=default
REDIS_PASSWORD=<your-redis-password>

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── CORS (comma-separated list of allowed frontend URLs) ─
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ── Cloudinary (image uploads) ──────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── OTP via Message Central ─────────────────────────────
MESSAGE_CENTRAL_CUSTOMER_ID=<your-customer-id>
MESSAGE_CENTRAL_AUTH_TOKEN=<your-auth-token>

# ── Admin Account ───────────────────────────────────────
ADMIN_EMAIL=admin@tendr.com
ADMIN_PASSWORD=<strong-password>

# ── Razorpay (payments) ─────────────────────────────────
# Get from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=<your-key-id>
RAZORPAY_KEY_SECRET=<your-key-secret>
